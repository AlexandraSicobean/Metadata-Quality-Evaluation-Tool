@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix ore:     <http://www.openarchives.org/ore/terms/> .
@prefix edm:     <http://www.europeana.eu/schemas/edm/> .
@prefix dc:      <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix ex:      <http://example.org/shapes/> .

# ── ore:Proxy ─────────────────────────────────────────────────────────────

ex:ProviderProxyShape
    a sh:NodeShape ;
    sh:targetClass ore:Proxy ;

    sh:property [ sh:path ore:proxyFor ; sh:minCount 1 ;
        sh:message "Missing ore:proxyFor" ; sh:severity sh:Violation ] ;
    sh:property [ sh:path ore:proxyIn ; sh:minCount 1 ;
        sh:message "Missing ore:proxyIn" ; sh:severity sh:Violation ] ;
    sh:property [ sh:path dc:title ; sh:minCount 1 ;
        sh:message "Missing dc:title" ; sh:severity sh:Warning ] ;
    sh:property [ sh:path edm:type ; sh:minCount 1 ;
        sh:message "Missing edm:type" ; sh:severity sh:Warning ] ;
    sh:property [ sh:path dc:date ; sh:minCount 1 ;
        sh:message "Missing dc:date" ; sh:severity sh:Warning ] .

# ── ore:Aggregation ────────────────────────────────────────────────────────

ex:AggregationShape
    a sh:NodeShape ;
    sh:targetClass ore:Aggregation ;

    sh:property [ sh:path edm:aggregatedCHO ; sh:minCount 1 ;
        sh:message "Missing edm:aggregatedCHO" ; sh:severity sh:Violation ] ;
    sh:property [ sh:path edm:provider ; sh:minCount 1 ;
        sh:message "Missing edm:provider" ; sh:severity sh:Violation ] ;
    sh:property [ sh:path edm:dataProvider ; sh:minCount 1 ;
        sh:message "Missing edm:dataProvider" ; sh:severity sh:Violation ] ;
    sh:property [ sh:path edm:rights ; sh:minCount 1 ;
        sh:message "Missing edm:rights" ; sh:severity sh:Violation ] ;
    sh:property [ sh:path edm:isShownAt ; sh:minCount 1 ;
        sh:message "Missing edm:isShownAt" ; sh:severity sh:Warning ] ;
    sh:property [ sh:path edm:isShownBy ; sh:minCount 1 ;
        sh:message "Missing edm:isShownBy" ; sh:severity sh:Warning ] .

# ── edm:WebResource ────────────────────────────────────────────────────────

ex:WebResourceShape
    a sh:NodeShape ;
    sh:targetClass edm:WebResource ;

    sh:property [ sh:path edm:rights ; sh:minCount 1 ;
        sh:message "Missing edm:rights" ; sh:severity sh:Warning ] ;
    sh:property [ sh:path dc:format ; sh:minCount 1 ;
        sh:message "Missing dc:format" ; sh:severity sh:Warning ] .

# ── edm:Agent ──────────────────────────────────────────────────────────────

ex:AgentShape
    a sh:NodeShape ;
    sh:targetClass edm:Agent ;

    sh:property [ sh:path skos:prefLabel ; sh:minCount 1 ;
        sh:message "Missing skos:prefLabel" ; sh:severity sh:Violation ] .

# ── edm:Place ──────────────────────────────────────────────────────────────

ex:PlaceShape
    a sh:NodeShape ;
    sh:targetClass edm:Place ;

    sh:property [ sh:path skos:prefLabel ; sh:minCount 1 ;
        sh:message "Missing skos:prefLabel" ; sh:severity sh:Violation ] .

# ── skos:Concept ───────────────────────────────────────────────────────────

ex:ConceptShape
    a sh:NodeShape ;
    sh:targetClass <http://www.w3.org/2004/02/skos/core#Concept> ;

    sh:property [ sh:path skos:prefLabel ; sh:minCount 1 ;
        sh:message "Missing skos:prefLabel" ; sh:severity sh:Violation ] .

# ── edm:TimeSpan ───────────────────────────────────────────────────────────

ex:TimeSpanShape
    a sh:NodeShape ;
    sh:targetClass edm:TimeSpan ;

    sh:property [ sh:path edm:begin ; sh:minCount 1 ;
        sh:message "Missing edm:begin" ; sh:severity sh:Warning ] ;
    sh:property [ sh:path edm:end ; sh:minCount 1 ;
        sh:message "Missing edm:end" ; sh:severity sh:Warning ] .